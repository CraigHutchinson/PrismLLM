{
  "version": "1.0",
  "description": "Seeded dictionary of verbose prompt phrases with terse alternatives and token savings. Used by pii_scan.py (filler detection) and pattern_analysis.py.",
  "patterns": [
    { "phrase": "we shall", "category": "royal_we", "terse_alt": "(use imperative verb directly)", "token_saving": 2, "regex": "\\bwe shall\\b" },
    { "phrase": "let us", "category": "royal_we", "terse_alt": "(use imperative verb directly)", "token_saving": 2, "regex": "\\blet us\\b" },
    { "phrase": "we will", "category": "royal_we", "terse_alt": "(use imperative verb directly)", "token_saving": 2, "regex": "\\bwe will\\b" },
    { "phrase": "we need to", "category": "royal_we", "terse_alt": "(use imperative verb directly)", "token_saving": 3, "regex": "\\bwe need to\\b" },
    { "phrase": "we should", "category": "royal_we", "terse_alt": "(use imperative verb directly)", "token_saving": 2, "regex": "\\bwe should\\b" },
    { "phrase": "could you please", "category": "politeness", "terse_alt": "(use imperative verb directly)", "token_saving": 3, "regex": "\\bcould you please\\b" },
    { "phrase": "please could you", "category": "politeness", "terse_alt": "(use imperative verb directly)", "token_saving": 3, "regex": "\\bplease could you\\b" },
    { "phrase": "would you be able to", "category": "politeness", "terse_alt": "(use imperative verb directly)", "token_saving": 5, "regex": "\\bwould you be able to\\b" },
    { "phrase": "if you don't mind", "category": "politeness", "terse_alt": "(omit)", "token_saving": 4, "regex": "\\bif you don.t mind\\b" },
    { "phrase": "I would like you to", "category": "preamble", "terse_alt": "(use imperative verb directly)", "token_saving": 5, "regex": "\\bI would like you to\\b" },
    { "phrase": "I want you to", "category": "preamble", "terse_alt": "(use imperative verb directly)", "token_saving": 4, "regex": "\\bI want you to\\b" },
    { "phrase": "your task is to", "category": "preamble", "terse_alt": "(use imperative verb directly)", "token_saving": 4, "regex": "\\byour task is to\\b" },
    { "phrase": "your job is to", "category": "preamble", "terse_alt": "(use imperative verb directly)", "token_saving": 4, "regex": "\\byour job is to\\b" },
    { "phrase": "I need you to", "category": "preamble", "terse_alt": "(use imperative verb directly)", "token_saving": 4, "regex": "\\bI need you to\\b" },
    { "phrase": "what I need is", "category": "preamble", "terse_alt": "(state the need directly)", "token_saving": 4, "regex": "\\bwhat I need is\\b" },
    { "phrase": "in this context", "category": "filler", "terse_alt": "(omit or merge into context block)", "token_saving": 3, "regex": "\\bin this context\\b" },
    { "phrase": "it is worth noting that", "category": "filler", "terse_alt": "Note:", "token_saving": 5, "regex": "\\bit is worth noting that\\b" },
    { "phrase": "it should be noted that", "category": "filler", "terse_alt": "Note:", "token_saving": 5, "regex": "\\bit should be noted that\\b" },
    { "phrase": "as previously mentioned", "category": "filler", "terse_alt": "(omit — refer to context)", "token_saving": 3, "regex": "\\bas previously mentioned\\b" },
    { "phrase": "as I mentioned", "category": "filler", "terse_alt": "(omit)", "token_saving": 3, "regex": "\\bas I mentioned\\b" },
    { "phrase": "as mentioned above", "category": "filler", "terse_alt": "(omit)", "token_saving": 3, "regex": "\\bas mentioned above\\b" },
    { "phrase": "to be honest", "category": "filler", "terse_alt": "(omit)", "token_saving": 3, "regex": "\\bto be honest\\b" },
    { "phrase": "basically", "category": "filler", "terse_alt": "(omit)", "token_saving": 1, "regex": "\\bbasically\\b" },
    { "phrase": "essentially", "category": "filler", "terse_alt": "(omit)", "token_saving": 1, "regex": "\\bessentially\\b" },
    { "phrase": "if possible", "category": "hedging", "terse_alt": "(omit unless genuinely conditional)", "token_saving": 2, "regex": "\\bif possible\\b" },
    { "phrase": "if you can", "category": "hedging", "terse_alt": "(omit — use imperative)", "token_saving": 3, "regex": "\\bif you can\\b" },
    { "phrase": "perhaps", "category": "hedging", "terse_alt": "(omit or make conditional explicit)", "token_saving": 1, "regex": "\\bperhaps\\b" },
    { "phrase": "maybe", "category": "hedging", "terse_alt": "(omit or make conditional explicit)", "token_saving": 1, "regex": "\\bmaybe\\b" },
    { "phrase": "sort of", "category": "vague", "terse_alt": "(use specific qualifier)", "token_saving": 2, "regex": "\\bsort of\\b" },
    { "phrase": "kind of", "category": "vague", "terse_alt": "(use specific qualifier)", "token_saving": 2, "regex": "\\bkind of\\b" },
    { "phrase": "a bit", "category": "vague", "terse_alt": "(use specific qualifier)", "token_saving": 2, "regex": "\\ba bit\\b" },
    { "phrase": "somewhat", "category": "vague", "terse_alt": "(use specific qualifier or omit)", "token_saving": 1, "regex": "\\bsomewhat\\b" },
    { "phrase": "make it better", "category": "vague", "terse_alt": "specify the improvement dimension", "token_saving": 0, "regex": "\\bmake it better\\b" },
    { "phrase": "improve it", "category": "vague", "terse_alt": "specify what to improve and how", "token_saving": 0, "regex": "\\bimprove it\\b" },
    { "phrase": "and also", "category": "bundling", "terse_alt": "split into two separate prompts", "token_saving": 2, "regex": "\\band also\\b" },
    { "phrase": "while you're at it", "category": "bundling", "terse_alt": "split into two separate prompts", "token_saving": 4, "regex": "\\bwhile you.re at it\\b" },
    { "phrase": "while you are at it", "category": "bundling", "terse_alt": "split into two separate prompts", "token_saving": 5, "regex": "\\bwhile you are at it\\b" },
    { "phrase": "additionally", "category": "bundling", "terse_alt": "new prompt or numbered list", "token_saving": 1, "regex": "\\badditionally\\b" },
    { "phrase": "furthermore", "category": "bundling", "terse_alt": "new prompt or numbered list", "token_saving": 1, "regex": "\\bfurthermore\\b" }
  ]
